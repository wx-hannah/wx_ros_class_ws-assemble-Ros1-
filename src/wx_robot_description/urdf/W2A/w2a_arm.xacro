<?xml version="1.0"?>
<robot name="arm_only"
      xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- 1. 定义一个世界坐标系作为根节点 -->
    <link name="world">
        <inertial>
            <mass value="1000.0" />
            <origin xyz="0 0 0" />
            <inertia ixx="1000" ixy="0" ixz="0" iyy="1000" iyz="0" izz="1000" />
        </inertial>
    </link>

    <!-- 2. 定义机械臂基座 (Base) -->
    <!-- 注意：这里我创建了一个简单的立方体作为底座，因为原URDF中的 arm_base_link 似乎是一个很小的连接件 -->
    <!-- 如果你想直接从 link_1 开始，可以把下面的 box 改成 <origin> 调整位置 -->
    <link name="arm_base_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="1.0" />
            <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.1 0.1 0.05" /> <!-- 一个简单的长方体基座 -->
            </geometry>
            <material name="dark_gray">
                <color rgba="0.2 0.2 0.2 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.1 0.1 0.05" />
            </geometry>
        </collision>
    </link>

    <!-- 3. 将机械臂固定在世界坐标系上 -->
    <joint name="world_to_arm" type="fixed">
        <parent link="world"/>
        <child link="arm_base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/> <!-- 可以调整 xyz 把机械臂抬高一点 -->
    </joint>

    <!-- ===================================================================== -->
    <!-- 以下部分是从你上传的 URDF 文档中提取的机械臂本体结构 -->
    <!-- ===================================================================== -->

    <!-- Link 1 -->
    <link name="link_1">
        <inertial>
            <origin xyz="0.00015999 -3.7029E-07 0.0067201" rpy="0 0 0" />
            <mass value="0.068148" />
            <inertia ixx="3.0609E-05" ixy="-5.9099E-11" ixz="-1.3841E-07" iyy="3.6584E-05" iyz="4.9301E-10" izz="2.3547E-05" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://wx_robot_description/meshes/W2A/arm/link_1.STL" />
            </geometry>
            <material name="">
                <color rgba="0.2 0.2 0.2 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://wx_robot_description/meshes/W2A/arm/link_1.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="joint_1" type="revolute">
        <origin xyz="0 0 0.072247" rpy="0 0 0" />
        <parent link="arm_base_link" />
        <child link="link_1" />
        <axis xyz="0 0 1" />
        <limit lower="-1.8" upper="1.8" effort="50" velocity="2" />
    </joint>

    <!-- Link 2 -->
    <link name="link_2">
        <inertial>
            <origin xyz="0.028477 -5.0821E-07 0.038913" rpy="0 0 0" />
            <mass value="0.049654" />
            <inertia ixx="1.8351E-05" ixy="-6.0792E-11" ixz="-6.4071E-08" iyy="3.1671E-05" iyz="3.6197E-10" izz="1.6517E-05" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://wx_robot_description/meshes/W2A/arm/link_2.STL" />
            </geometry>
            <material name="">
                <color rgba="0.2 0.2 0.2 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://wx_robot_description/meshes/W2A/arm/link_2.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="joint_2" type="revolute">
        <origin xyz="-0.028151 0 0.034" rpy="0 0 0" />
        <parent link="link_1" />
        <child link="link_2" />
        <axis xyz="1 0 0" />
        <limit lower="-1.8" upper="1.8" effort="50" velocity="3" />
    </joint>

    <!-- Link 3 -->
    <link name="link_3">
        <inertial>
            <origin xyz="0.028363 -4.679E-07 0.054247" rpy="0 0 0" />
            <mass value="0.053931" />
            <inertia ixx="3.1912E-05" ixy="-6.0429E-11" ixz="-9.8626E-08" iyy="4.873E-05" iyz="4.797E-10" izz="2.0341E-05" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://wx_robot_description/meshes/W2A/arm/link_3.STL" />
            </geometry>
            <material name="">
                <color rgba="0.2 0.2 0.2 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://wx_robot_description/meshes/W2A/arm/link_3.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="joint_3" type="revolute">
        <origin xyz="9.8516E-05 0 0.061" rpy="0 0 0" />
        <parent link="link_2" />
        <child link="link_3" />
        <axis xyz="1 0 0" />
        <limit lower="-1.8" upper="1.8" effort="50" velocity="3" />
    </joint>

    <!-- Link 4 -->
    <link name="link_4">
        <inertial>
            <origin xyz="0.028255 -0.0047504 0.06611" rpy="0 0 0" />
            <mass value="0.10537" />
            <inertia ixx="9.6221E-05" ixy="-3.6252E-10" ixz="2.7529E-08" iyy="7.3811E-05" iyz="7.9136E-06" izz="6.9537E-05" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://wx_robot_description/meshes/W2A/arm/link_4.STL" />
            </geometry>
            <material name="">
                <color rgba="0.2 0.2 0.2 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://wx_robot_description/meshes/W2A/arm/link_4.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="joint_4" type="revolute">
        <origin xyz="0 0 0.081" rpy="0 0 0" />
        <parent link="link_3" />
        <child link="link_4" />
        <axis xyz="1 0 0" />
        <limit lower="-1.8" upper="1.8" effort="50" velocity="3" />
    </joint>

    <!-- Link 5 -->
    <link name="link_5">
        <inertial>
            <origin xyz="4.4212E-05 0.0041269 0.025698" rpy="0 0 0" />
            <mass value="0.098063" />
            <inertia ixx="3.7917E-05" ixy="1.4713E-07" ixz="-1.1994E-07" iyy="5.5952E-05" iyz="2.3438E-06" izz="5.2518E-05" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://wx_robot_description/meshes/W2A/arm/link_5.STL" />
            </geometry>
            <material name="">
                <color rgba="0.2 0.2 0.2 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://wx_robot_description/meshes/W2A/arm/link_5.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="joint_5" type="revolute">
        <origin xyz="0.02825 0 0.0975" rpy="0 0 0" />
        <parent link="link_4" />
        <child link="link_5" />
        <axis xyz="0 0 -1" />
        <limit lower="-1.8" upper="1.8" effort="50" velocity="3" />
    </joint>

    <!-- Claw Link 1 -->
    <link name="claw_link_1">
        <inertial>
            <origin xyz="0.0054256 -0.015308 0.019147" rpy="0 0 0" />
            <mass value="0.018231" />
            <inertia ixx="6.9914E-06" ixy="-3.7017E-08" ixz="1.3043E-06" iyy="6.7797E-06" iyz="4.9174E-08" izz="2.5386E-06" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://wx_robot_description/meshes/W2A/arm/claw_link_1.STL" />
            </geometry>
            <material name="">
                <color rgba="0.2 0.2 0.2 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://wx_robot_description/meshes/W2A/arm/claw_link_1.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="claw_joint_1" type="revolute">
        <origin xyz="-0.028 0.015 0.0462" rpy="0 0 0" />
        <parent link="link_5" />
        <child link="claw_link_1" />
        <axis xyz="0 -1 0" />
        <limit lower="-1.5" upper="1.5" effort="10" velocity="3" />
    </joint>

    <!-- Claw Link 2 -->
    <link name="claw_link_2">
        <inertial>
            <origin xyz="-0.0054256 -0.015308 0.019147" rpy="0 0 0" />
            <mass value="0.018231" />
            <inertia ixx="6.9914E-06" ixy="3.7016E-08" ixz="-1.3043E-06" iyy="6.7797E-06" iyz="4.9173E-08" izz="2.5386E-06" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://wx_robot_description/meshes/W2A/arm/claw_link_2.STL" />
            </geometry>
            <material name="">
                <color rgba="0.2 0.2 0.2 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://wx_robot_description/meshes/W2A/arm/claw_link_2.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="claw_joint_2" type="revolute">
        <origin xyz="0.027609 0.015 0.0462" rpy="0 0 0" />
        <parent link="link_5" />
        <child link="claw_link_2" />
        <axis xyz="0 -1 0" />
        <limit lower="-1.5" upper="1.5" effort="10" velocity="3" />
    </joint>

    <!-- ===================================================================== -->
    <!-- 4. 传动装置 (Transmission) -->
    <!-- 这部分是让 Gazebo 能控制关节的关键 -->
    <!-- ===================================================================== -->
    
    <!-- 你需要确保这里引用的宏 (xacro:transmission_block) 在你的环境中已定义 -->
    <!-- 如果报错，可以先注释掉下面这行，或者直接使用下面的硬编码方式 -->

    <!-- 方式 A：如果你有 transmission_block 宏 -->
    <!-- <xacro:transmission_block joint_name="joint_1"/> -->
    <!-- <xacro:transmission_block joint_name="joint_2"/> -->
    <!-- ... 以此类推 ... -->

    <!-- 方式 B：直接硬编码 (推荐，避免宏找不到的错误) -->
    <transmission name="tran_joint_1">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="joint_1">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="motor_joint_1">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <transmission name="tran_joint_2">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="joint_2">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="motor_joint_2">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <transmission name="tran_joint_3">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="joint_3">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="motor_joint_3">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <transmission name="tran_joint_4">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="joint_4">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="motor_joint_4">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <transmission name="tran_joint_5">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="joint_5">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="motor_joint_5">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <transmission name="tran_claw_1">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="claw_joint_1">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="motor_claw_1">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <transmission name="tran_claw_2">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="claw_joint_2">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="motor_claw_2">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <gazebo>
      <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
        <robotNamespace>/</robotNamespace>
      </plugin>
    </gazebo>

</robot>