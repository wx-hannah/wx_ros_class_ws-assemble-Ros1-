<launch>
  
  <param name="use_sim_time" value="true" />

  <arg name="map_name" default="my_lab.yaml" />

  <node name="map_server" pkg="map_server" type="map_server" args="$(find wx_robot_description)/maps/$(arg map_name)"/>

  <include file="$(find wx_robot_description)/launch/include/amcl.launch.xml" />

  <include file="$(find wx_robot_description)/launch/include/move_base.launch.xml" />
  
</launch>
