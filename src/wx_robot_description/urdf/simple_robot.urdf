<?xml version="1.0"?>
<robot name="mobile_base">

  <!-- 底盘 base_link -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.4 0.2 0.1"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.05"/>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.2 0.1"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.05"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.02"/>
    </inertial>
  </link>

  <!-- 左轮 wheel_left_link -->
  <link name="wheel_left_link">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.06"/>
      </geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.04" radius="0.06"/>
      </geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>

  <!-- 右轮 wheel_right_link -->
  <link name="wheel_right_link">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.06"/>
      </geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.04" radius="0.06"/>
      </geometry>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>

  <!-- 万向轮 caster_link -->
  <link name="caster_link">
    <visual>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
  </link>

  <!-- 左轮关节 -->
  <joint name="wheel_left_joint" type="revolute">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="-0.08 -0.11 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" lower="-1e16" upper="1e16" velocity="10"/>
  </joint>

  <!-- 右轮关节 -->
  <joint name="wheel_right_joint" type="revolute">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="-0.08 0.11 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" lower="-1e16" upper="1e16" velocity="10"/>
  </joint>

  <!-- 万向轮关节 -->
  <joint name="base_to_caster" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="0.17 0 -0.02"/>
  </joint>

  <!-- Gazebo 材质 -->
  <gazebo reference="base_link">
    <material>Gazebo/Gray</material>
  </gazebo>
  <gazebo reference="wheel_left_link">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="wheel_right_link">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="caster_link">
    <material>Gazebo/Gray</material>
  </gazebo>

  <!-- 差速控制器（已修复） -->
  <gazebo>
    <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <alwaysOn>true</alwaysOn>
      <updateRate>50</updateRate>
      <leftJoint>wheel_left_joint</leftJoint>
      <rightJoint>wheel_right_joint</rightJoint>
      <wheelSeparation>0.22</wheelSeparation>
      <wheelDiameter>0.12</wheelDiameter>
      <wheelTorque>10</wheelTorque>
      <wheelSpeed>5.0</wheelSpeed>
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_link</robotBaseFrame>
    </plugin>
  </gazebo>

</robot>

