<launch>
  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <rosparam file="$(find wx_robot_description)/config/costmap/costmap_common_params.yaml" command="load" ns="global_costmap" />
    <rosparam file="$(find wx_robot_description)/config/costmap/costmap_common_params.yaml" command="load" ns="local_costmap" />
    <rosparam file="$(find wx_robot_description)/config/costmap/local_costmap_params.yaml" command="load"/>
    <rosparam file="$(find wx_robot_description)/config/costmap/global_costmap_params.yaml" command="load" />
    <rosparam file="$(find wx_robot_description)/config/planner/dwa_local_planner_params.yaml" command="load" />
    <rosparam file="$(find wx_robot_description)/config/planner/global_planner_params.yaml" command="load" />
    <rosparam file="$(find wx_robot_description)/config/move_base_params.yaml" command="load" />
  </node>
</launch>
